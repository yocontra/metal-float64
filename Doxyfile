# Doxygen configuration for soft-fp64.
#
# Generated HTML lives under docs/html. The `docs` job in
# .github/workflows/ci.yml builds it as a CI artifact with
# WARN_AS_ERROR = FAIL_ON_WARNINGS.
#
# Keep options minimal — every flag below is either a Doxygen non-default
# that shapes the public surface, or a CI discipline toggle.

PROJECT_NAME           = "soft-fp64"
PROJECT_BRIEF          = "Pure-software IEEE-754 binary64 library"
PROJECT_NUMBER         =
OUTPUT_DIRECTORY       = docs

# Language & input layout
INPUT                  = include README.md
FILE_PATTERNS          = *.h *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md
STRIP_FROM_PATH        = include
JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES

# Expand visibility attributes / export macros so Doxygen sees plain
# `double sf64_add(double, double);` rather than the attributed form.
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = "SF64_EXPORT=" \
                         "__attribute__(x)=" \
                         "[[gnu::visibility(\"default\")]]=" \
                         "[[deprecated(x)]]="

# Public header is C ABI but implemented in C++; we want every prototype
# extracted, not just those with /** ... */ blocks, so the Modules page
# shows the full surface. Headers without comments still appear, making
# gaps in the documentation visible instead of invisible.
EXTRACT_ALL            = YES
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
OPTIMIZE_OUTPUT_FOR_C  = YES

# Output formats — HTML only; no LaTeX/PDF pipeline in CI.
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_XML           = NO

# CI discipline: turn Doxygen warnings into errors so documentation drift
# is caught on PRs the same way clang-format drift is.
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_IF_INCOMPLETE_DOC = YES
WARN_AS_ERROR          = FAIL_ON_WARNINGS

# Search & navigation
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO
DISABLE_INDEX          = NO
SEARCHENGINE           = YES

# Dot graphs — off; nothing in a single public header benefits from them
# and graphviz would become a CI dependency for no payoff.
HAVE_DOT               = NO
